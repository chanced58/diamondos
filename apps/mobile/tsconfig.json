{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "paths": {
      "@/*": ["./src/*"],
      "@baseball/shared": ["../../packages/shared/src/index.ts"],
      "@baseball/database": ["../../packages/database/src/index.ts"],
      "@baseball/ui": ["../../packages/ui/src/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.d.ts", "expo-env.d.ts"],
  "exclude": ["node_modules"]
}
