# ─────────────────────────────────────────────────────────────
# Supabase (web app — exposed to browser via NEXT_PUBLIC_ prefix)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# Resend (email notifications — server-only)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key

# ─────────────────────────────────────────────────────────────
# Anthropic (Tier 7 AI features — server-only, never expose)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ─────────────────────────────────────────────────────────────
# Google Maps (web app — exposed to browser via NEXT_PUBLIC_ prefix)
# Enable: Maps JavaScript API + Places API in Google Cloud Console
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────────
# Supabase (mobile app — exposed to bundle via EXPO_PUBLIC_ prefix)
# ─────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────
# Edge Functions (set via: supabase secrets set KEY=value)
# ─────────────────────────────────────────────────────────────
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# EXPO_ACCESS_TOKEN=your-expo-push-access-token
#
# Tier 5 — Integration Hub
# ICS_FEED_SECRET signs per-team calendar-subscription URLs. Treat this as a
# permanent project-level secret: rotating it invalidates every team's
# subscribed ICS URL simultaneously. Use a random value ≥ 32 characters.
# ICS_FEED_SECRET=
